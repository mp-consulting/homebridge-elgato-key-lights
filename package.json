{
  "displayName": "Elgato Key Lights",
  "name": "@mp-consulting/homebridge-elgato-key-lights",
  "version": "1.0.10",
  "description": "A Homebridge plugin for Elgato Key Light and Key Light Air",
  "author": "MP Consulting",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mp-consulting/homebridge-elgato-key-lights.git"
  },
  "bugs": {
    "url": "https://github.com/mp-consulting/homebridge-elgato-key-lights/issues"
  },
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/mickaelpalma"
  },
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "watch": "npm run build && npm link && nodemon",
    "copy:ui-kit": "mkdir -p homebridge-ui/public/lib && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.css homebridge-ui/public/lib/ && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.js homebridge-ui/public/lib/",
    "build": "npm run copy:ui-kit && rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "homebridge-plugin",
    "elgato",
    "keylight",
    "key lights",
    "key light air",
    "streaming",
    "keylight air"
  ],
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.3",
    "axios": "^1.14.0",
    "bonjour-service": "^1.3.0",
    "homebridge-lib": "^7.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mp-consulting/homebridge-ui-kit": "^1.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.1.0",
    "homebridge": "^2.0.0-beta.55",
    "homebridge-config-ui-x": "^5.21.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json"
  ]
}
